rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isLoggedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isLoggedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // 특정 권한이 있는지 확인하는 함수 (단일 문서 읽기)
    function hasPermission(groupId, perm) {
      return exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)) &&
        (
          get(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)).data.role == 'owner' ||
          (
            get(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)).data.role == 'manager' &&
            get(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)).data.permissions[perm] == true
          )
        );
    }

    function isValidNoticeType(value) {
      return value in ['update', 'event', 'maintenance', 'announcement'];
    }

    function isStringOrNull(value) {
      return value == null || value is string;
    }

    function isNumberOrNull(value) {
      return value == null || value is int || value is float;
    }

    function isTimestampOrNull(value) {
      return value == null || value is timestamp;
    }

    function isValidAppNoticeBase(noticeId, data) {
      return data.keys().hasOnly([
          'id',
          'title',
          'content',
          'notice_type',
          'min_app_version',
          'android_url',
          'ios_url',
          'default_url',
          'is_active',
          'priority',
          'expired_at',
          'updated_at',
          'created_at',
        ]) &&
        data.id is string &&
        data.id == noticeId &&
        data.title is string &&
        data.title.size() > 0 &&
        data.title.size() <= 120 &&
        data.content is string &&
        data.content.size() > 0 &&
        isValidNoticeType(data.notice_type) &&
        isNumberOrNull(data.min_app_version) &&
        isStringOrNull(data.android_url) &&
        isStringOrNull(data.ios_url) &&
        isStringOrNull(data.default_url) &&
        data.is_active is bool &&
        (data.priority is int || data.priority is float) &&
        data.priority >= 0 &&
        isTimestampOrNull(data.expired_at);
    }

    function isValidAppNoticeCreate(noticeId, data) {
      return isValidAppNoticeBase(noticeId, data) &&
        data.updated_at == request.time &&
        data.created_at == request.time;
    }

    function isValidAppNoticeUpdate(noticeId, data) {
      return isValidAppNoticeBase(noticeId, data) &&
        data.updated_at == request.time &&
        data.created_at == resource.data.created_at;
    }

    function isVisibleAppNotice() {
      return resource.data.is_active == true &&
        (resource.data.expired_at == null || resource.data.expired_at > request.time);
    }

    // ── 관리자 ──────────────────────────────────────────────────────────────
    match /admins/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    // ── 앱 공지 ────────────────────────────────────────────────────────────
    match /app_notices/{noticeId} {
      allow read: if isAdmin() || isVisibleAppNotice();
      allow create: if isAdmin() && isValidAppNoticeCreate(noticeId, request.resource.data);
      allow update: if isAdmin() && isValidAppNoticeUpdate(noticeId, request.resource.data);
      allow delete: if isAdmin();
    }

    // ── 유저 ────────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isLoggedIn();
      allow write: if isOwner(uid);

      match /joined_groups/{groupId} {
        allow read: if isOwner(uid) || isAdmin();
        // 방장/권한 있는 사람이 가입 승인·강퇴 시 다른 유저의 가입 그룹 문서를 생성/수정/삭제할 수 있도록 허용
        allow create, update, delete: if isOwner(uid) ||
          hasPermission(groupId, 'can_manage_permissions') ||
          isAdmin();
      }

      match /notifications/{notiId} {
        allow read: if isOwner(uid) || isAdmin();
        // 다른 유저가 초대를 보낼 수 있도록 허용 (invite 타입만 가능)
        allow create: if isLoggedIn() && request.resource.data.type == 'invite';
        allow update, delete: if isOwner(uid) || isAdmin();
      }

      match /{allSubcollections=**} {
        allow read, write: if isOwner(uid) || isAdmin();
      }
    }

    // ── 채팅방 ──────────────────────────────────────────────────────────────
    match /chat_rooms/{roomId} {
      allow read: if isAdmin() || (isLoggedIn() && (
        request.auth.uid in resource.data.member_ids || 
        (resource.data.ref_group_id != null && exists(/databases/$(database)/documents/groups/$(resource.data.ref_group_id)/members/$(request.auth.uid))) ||
        resource.data.type == 'group_all'
      ));
      allow create: if isLoggedIn();
      allow update: if isAdmin() || (
        isLoggedIn() && (
          request.auth.uid in resource.data.member_ids ||
          (resource.data.ref_group_id != null && hasPermission(resource.data.ref_group_id, 'can_manage_permissions'))
        )
      );

      match /messages/{messageId} {
        allow read: if isAdmin() || (isLoggedIn() && request.auth.uid in get(/databases/$(database)/documents/chat_rooms/$(roomId)).data.member_ids);
        allow create: if isAdmin() || (isLoggedIn() && request.auth.uid in getAfter(/databases/$(database)/documents/chat_rooms/$(roomId)).data.member_ids);
        allow update: if isAdmin() || (isLoggedIn() && request.auth.uid == resource.data.sender_id);
      }

      match /room_members/{memberId} {
        allow read: if isAdmin() || (isLoggedIn() && (request.auth.uid == memberId || request.auth.uid in get(/databases/$(database)/documents/chat_rooms/$(roomId)).data.member_ids));
        allow write: if isAdmin() || (isLoggedIn() && (request.auth.uid == memberId || request.auth.uid in getAfter(/databases/$(database)/documents/chat_rooms/$(roomId)).data.member_ids));
      }

      match /calls/{callId} {
        allow read: if isAdmin() || (isLoggedIn() && request.auth.uid in get(/databases/$(database)/documents/chat_rooms/$(roomId)).data.member_ids);
        allow write: if false;

        match /participants/{uid} {
          allow read: if isAdmin() || (isLoggedIn() && request.auth.uid in get(/databases/$(database)/documents/chat_rooms/$(roomId)).data.member_ids);
          allow create, delete: if false;
          allow update: if request.auth != null
            && request.auth.uid == uid
            && request.resource.data.diff(resource.data).changedKeys().hasOnly(['last_seen', 'is_muted'])
            && request.resource.data.uid == resource.data.uid
            && request.resource.data.joined_at == resource.data.joined_at
            && request.resource.data.left_at == resource.data.left_at
            && request.resource.data.role == resource.data.role
            && request.resource.data.device == resource.data.device
            && request.resource.data.is_speaking == resource.data.is_speaking;
        }
      }

      match /{allSubcollections=**} {
        allow read: if isAdmin() || (isLoggedIn() && request.auth.uid in get(/databases/$(database)/documents/chat_rooms/$(roomId)).data.member_ids);
        allow write: if isAdmin() || (isLoggedIn() && (
          request.auth.uid in getAfter(/databases/$(database)/documents/chat_rooms/$(roomId)).data.member_ids ||
          (getAfter(/databases/$(database)/documents/chat_rooms/$(roomId)).data.ref_group_id != null && hasPermission(getAfter(/databases/$(database)/documents/chat_rooms/$(roomId)).data.ref_group_id, 'can_manage_permissions'))
        ));
      }
    }

    // ── AI 회의록 관리 ──────────────────────────────────────────────────
    match /ai_jobs/{jobId} {
      allow read: if isLoggedIn() && request.auth.uid in get(/databases/$(database)/documents/chat_rooms/$(resource.data.roomId)).data.member_ids;
      allow create: if isLoggedIn();
      allow update: if false;
    }

    // ── 그룹 ────────────────────────────────────────────────────────────────
    match /groups/{groupId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn();
      allow update: if isAdmin() || 
                    hasPermission(groupId, 'can_manage_permissions') ||
                    (
                      isLoggedIn() &&
                      request.resource.data.diff(resource.data).changedKeys().hasOnly(['member_count']) &&
                      (
                        request.resource.data.member_count == resource.data.member_count + 1 ||
                        request.resource.data.member_count == resource.data.member_count - 1
                      )
                    );

      // AI 회의록 사용량 관리
      match /usage/months/{monthId} {
        allow read: if isLoggedIn() && exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid));
        allow write: if isAdmin() || hasPermission(groupId, 'can_manage_permissions');
      }

      match /likes/{uid} {
        allow read: if isLoggedIn();
        allow create, delete: if isLoggedIn() && request.auth.uid == uid;
      }

      match /members/{memberId} {
        allow read: if isLoggedIn();
        allow write: if isOwner(memberId) || hasPermission(groupId, 'can_manage_permissions') || isAdmin();
      }
      
      match /banned/{memberId} {
        allow read: if isLoggedIn() && exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid));
        allow write: if hasPermission(groupId, 'can_manage_permissions');
      }

      match /join_requests/{requestId} {
        allow read: if hasPermission(groupId, 'can_manage_permissions') || (isLoggedIn() && request.auth.uid == requestId);
        allow create: if isLoggedIn() && request.auth.uid == requestId;
        allow update, delete: if hasPermission(groupId, 'can_manage_permissions') || (isLoggedIn() && request.auth.uid == requestId);
      }

      match /{allSubcollections=**} {
        allow read: if isLoggedIn();
        allow write: if hasPermission(groupId, 'can_manage_permissions') || exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid));
      }
    }

    // ── 공통 ───────────────────────────────────────────────────────────────
    match /reports/{reportId} {
      allow read, write: if isAdmin();
      allow create: if isLoggedIn();
    }
    match /payments/{paymentId} {
      allow read: if isAdmin() || (isLoggedIn() && request.auth.uid == resource.data.payer_uid);
      allow write: if isAdmin();
    }
  }
}
