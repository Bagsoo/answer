rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isLoggedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // ── 유저 ────────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isLoggedIn();
      allow write: if isOwner(uid);

      match /fcm_tokens/{tokenId} {
        allow read, write: if isOwner(uid);
      }
      match /group_notification_settings/{groupId} {
        allow read, write: if isOwner(uid);
      }
      match /joined_groups/{groupId} {
        allow read, write: if isOwner(uid);
      }
    }

    // ── 채팅방 ──────────────────────────────────────────────────────────────
    match /chat_rooms/{roomId} {
      allow read: if isLoggedIn() &&
        request.auth.uid in resource.data.member_ids;
      allow create: if isLoggedIn();
      allow update: if isLoggedIn() &&
        request.auth.uid in resource.data.member_ids;

      match /messages/{messageId} {
        allow read, write: if isLoggedIn() &&
          request.auth.uid in
            get(/databases/$(database)/documents/chat_rooms/$(roomId))
              .data.member_ids;
      }
      match /room_members/{memberId} {
        allow read: if isLoggedIn() &&
          request.auth.uid in
            get(/databases/$(database)/documents/chat_rooms/$(roomId))
              .data.member_ids;
        allow write: if isOwner(memberId);
      }
      match /notices/{noticeId} {
        allow read: if isLoggedIn() &&
          request.auth.uid in
            get(/databases/$(database)/documents/chat_rooms/$(roomId))
              .data.member_ids;
        allow write: if isLoggedIn() &&
          request.auth.uid in
            get(/databases/$(database)/documents/chat_rooms/$(roomId))
              .data.member_ids;
      }
      match /scheduled_messages/{msgId} {
        allow read, write: if isLoggedIn() &&
          request.auth.uid in
            get(/databases/$(database)/documents/chat_rooms/$(roomId))
              .data.member_ids;
      }
    }

    // ── 그룹 ────────────────────────────────────────────────────────────────
    match /groups/{groupId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn();
      allow update: if isLoggedIn() &&
        exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid));

      match /members/{memberId} {
        allow read: if isLoggedIn();
        allow write: if isLoggedIn();
      }
      match /join_requests/{requestId} {
        allow read, write: if isLoggedIn();
      }
      match /schedules/{scheduleId} {
        allow read: if isLoggedIn();
        allow write: if isLoggedIn() &&
          exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid));
      }
    }
  }
}