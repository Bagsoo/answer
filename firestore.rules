rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isLoggedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isLoggedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function canHideChatMessage(roomId) {
      let room = get(/databases/$(database)/documents/chat_rooms/$(roomId)).data;
      let isGroup = room.keys().hasAll(['ref_group_id']) && room.ref_group_id != null;
      let member = isGroup ? get(/databases/$(database)/documents/groups/$(room.ref_group_id)/members/$(request.auth.uid)).data : null;
      return isGroup && member != null && (member.role == 'owner' || member.permissions.can_create_sub_chat == true);
    }

    // ── 관리자 ──────────────────────────────────────────────────────────────
    match /admins/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    // ── 컬렉션 그룹 ──────────────────────────────────────────────────────────
    match /{path=**}/schedules/{scheduleId} {
      allow read: if isLoggedIn() &&
        (resource.data.rsvp != null && 
         resource.data.rsvp[request.auth.uid] == 'yes');
    }

    // ── 유저 ────────────────────────────────────────────────────────────────
    match /phone_index/{phoneE164} {
      allow read: if isLoggedIn() && (isAdmin() || resource == null || resource.data.uid == request.auth.uid);

      allow create: if isLoggedIn() &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.is_deleted == false;

      allow update: if isLoggedIn() &&
        (resource.data.uid == request.auth.uid || resource.data.is_deleted == true) &&
        request.resource.data.uid == request.auth.uid;

      allow delete: if false;
    }

    match /users/{uid} {
      allow read: if isLoggedIn();
      allow write: if isOwner(uid);

      match /friends/{friendUid} {
        allow read: if isOwner(uid) || isAdmin();
        allow write: if isOwner(uid);
      }
      match /blocked/{blockedUid} {
        allow read: if isOwner(uid) || isAdmin();
        allow write: if isOwner(uid);
      }

      match /fcm_tokens/{tokenId} {
        allow read: if isOwner(uid) || isAdmin();
        allow write: if isOwner(uid);
      }
      match /group_notification_settings/{groupId} {
        allow read: if isOwner(uid) || isAdmin();
        allow write: if isOwner(uid);
      }
      match /joined_groups/{groupId} {
        allow read: if isOwner(uid) || isAdmin();
        allow write: if isOwner(uid);
      }
      match /memos/{memoId} {
        allow read: if isOwner(uid) || isAdmin();
        allow write: if isOwner(uid);
      }
      match /personal_schedules/{scheduleId} {
        allow read, write: if isOwner(uid);
      }
    }

    // ── 채팅방 ──────────────────────────────────────────────────────────────
    match /chat_rooms/{roomId} {
      allow read: if isAdmin() || (isLoggedIn() && (
        request.auth.uid in resource.data.member_ids || 
        (
          resource.data.ref_group_id != null && 
          exists(/databases/$(database)/documents/groups/$(resource.data.ref_group_id)/members/$(request.auth.uid))
        )
      ));
      allow create: if isLoggedIn();
      allow update: if isAdmin() || (
        isLoggedIn() &&
        request.auth.uid in resource.data.member_ids
      );

      match /messages/{messageId} {
        allow read: if isAdmin() || (
          isLoggedIn() &&
          request.auth.uid in
            get(/databases/$(database)/documents/chat_rooms/$(roomId))
              .data.member_ids
        );
        allow create, delete: if isLoggedIn() &&
          request.auth.uid in
            get(/databases/$(database)/documents/chat_rooms/$(roomId))
              .data.member_ids;
              
        allow update: if isAdmin() || (
          isLoggedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/chat_rooms/$(roomId)).data.member_ids &&
          (
            (request.auth.uid == resource.data.sender_id && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'is_deleted', 'deleted_at', 'edited', 'updated_at'])) ||
            (request.resource.data.diff(resource.data).affectedKeys().hasAny(['is_hidden', 'hidden_by', 'hidden_at', 'is_system']) && canHideChatMessage(roomId))
          )
        );
      }
      match /room_members/{memberId} {
        allow read: if isAdmin() || (
          isLoggedIn() &&
          request.auth.uid in
            get(/databases/$(database)/documents/chat_rooms/$(roomId))
              .data.member_ids
        );
        allow write: if isLoggedIn() &&
          request.auth.uid in
            getAfter(/databases/$(database)/documents/chat_rooms/$(roomId))
              .data.member_ids;
      }
      match /notices/{noticeId} {
        allow read: if isAdmin() || (
          isLoggedIn() &&
          request.auth.uid in
            get(/databases/$(database)/documents/chat_rooms/$(roomId))
              .data.member_ids
        );
        allow write: if isLoggedIn() &&
          request.auth.uid in
            get(/databases/$(database)/documents/chat_rooms/$(roomId))
              .data.member_ids;
      }
      match /message_assets/{assetId} {
        allow read: if isAdmin() || (
          isLoggedIn() &&
          request.auth.uid in
            get(/databases/$(database)/documents/chat_rooms/$(roomId))
              .data.member_ids
        );
        allow create, delete: if isLoggedIn() &&
          request.auth.uid in
            get(/databases/$(database)/documents/chat_rooms/$(roomId))
              .data.member_ids;
        allow update: if isAdmin() || (
          isLoggedIn() &&
          request.auth.uid in
            get(/databases/$(database)/documents/chat_rooms/$(roomId))
              .data.member_ids &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['is_starred'])
        );
      }
      match /scheduled_messages/{msgId} {
        allow read: if isAdmin() || (
          isLoggedIn() &&
          request.auth.uid in
            get(/databases/$(database)/documents/chat_rooms/$(roomId))
              .data.member_ids
        );
        allow write: if isLoggedIn() &&
          request.auth.uid in
            get(/databases/$(database)/documents/chat_rooms/$(roomId))
              .data.member_ids;
      }
    }

    // ── 그룹 ────────────────────────────────────────────────────────────────
    match /groups/{groupId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn();
      allow update: if isAdmin() || (isLoggedIn() &&
        exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)));

      match /members/{memberId} {
        allow read: if isLoggedIn();
        allow write: if isLoggedIn() || isAdmin();
      }
      match /join_requests/{requestId} {
        allow read: if isLoggedIn();
        allow write: if isLoggedIn() || isAdmin();
      }
      match /schedules/{scheduleId} {
        allow read: if isLoggedIn();
        allow write: if isLoggedIn() &&
          exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid));
      }
      match /boards/{boardId} {
        allow read: if isLoggedIn() &&
          exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid));
        allow write: if isLoggedIn() &&
          exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid));
      }
      match /posts/{postId} {
        allow read: if isLoggedIn() &&
          exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid));
        allow write: if isLoggedIn() &&
          exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid));
      }
      match /posts/{postId}/comments/{commentId} {
        allow read: if isLoggedIn() &&
          exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid));
        allow write: if isLoggedIn() &&
          exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid));
      }
      match /notices/{noticeId} {
        allow read: if isLoggedIn() &&
          exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid));
        allow write: if isLoggedIn() &&
          get(/databases/$(database)/documents/groups/$(groupId)).data.plan == 'pro' &&
          (
            get(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)).data.role == 'owner' ||
            get(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)).data.permissions.can_edit_group_info == true
          );
      }
      match /settlements/{settlementId} {
        allow read: if isLoggedIn() &&
          exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid));
        allow write: if isLoggedIn() &&
          exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid));
      }
    }

    // ── 신고 및 결제 ───────────────────────────────────────────────────────
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
      allow create: if isLoggedIn();
    }

    match /payments/{paymentId} {
      allow read: if isAdmin() || (isLoggedIn() && request.auth.uid == resource.data.payer_uid);
      allow write: if isAdmin();
    }
  }
}
